#!/bin/bash --login
#BATCH Lines for Resource Request ##########

#SBATCH --time=1-00:00:00             # limit of wall clock time - how long the job will run (same as -t)
#SBATCH --nodes=1                   # number of different nodes - could be an exact number or a range of nodes (same as -N)
#SBATCH --ntasks=1                    # number of tasks - how many tasks (nodes) that you require (same as -n)
#SBATCH --cpus-per-task=3          # number of CPUs (or cores) per task (same as -c)
#SBATCH --mem-per-cpu=10G            # memory required per allocated CPU (or core) - amount of memory (in bytes)
#SBATCH --gres=gpu:a100:1
#SBATCH --job-name=rtoscout             # you can give your job a name for easier identification (same as -J)
#SBATCH --mail-user=jieyaqi@msu.edu
#SBATCH --mail-type=ALL
#SBATCH --account=data-machine
#SBATCH -o  run_log
########## Command Lines to Run ##########

if [[ -f ".env" ]]; then
  set -a
  source ".env"
  set +a
fi

module purge
module load poetry/1.8.3
module load Ollama/0.15.5

ollama serve > ollama.log 2>&1 &
for i in {1..60}; do
  curl -s "$OLLAMA_BASE_URL/api/tags" >/dev/null && break
  sleep 1
done
ollama pull "${OLLAMA_MODEL}"

poetry run python run.py --input "${COMPANY_JSON}"

scontrol show job $SLURM_JOB_ID     ### write job information to output file
